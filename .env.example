CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_API_TOKEN=
# Optional if database_id is present in wrangler.toml
CLOUDFLARE_D1_DATABASE_ID=

EDINET_URL=https://api.edinet-fsa.go.jp/api/v2
EDINET_API_KEY=

# Optional throttling/backoff tuning for ingestion
EDINET_MIN_REQUEST_INTERVAL_SECONDS=1.0
EDINET_MAX_ATTEMPTS=4
EDINET_BACKOFF_BASE_SECONDS=1.0
EDINET_BACKOFF_MAX_SECONDS=30.0

YFINANCE_MIN_REQUEST_INTERVAL_SECONDS=2.5
YFINANCE_MAX_ATTEMPTS=4
YFINANCE_BACKOFF_BASE_SECONDS=5.0
YFINANCE_BACKOFF_MAX_SECONDS=60.0
